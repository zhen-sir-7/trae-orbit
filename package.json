{
  "name": "trae-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch --tsconfig tsconfig.json api/index.ts",
    "dev:all": "concurrently -k -n server,web -c blue,green \"npm:dev:server\" \"npm:dev\"",
    "server": "tsx api/index.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc -b --noEmit",
    "build:server": "node esbuild.config.mjs",
    "cap:sync": "npm run build && cap sync",
    "cap:open": "cap open android",
    "cap:run": "npm run build && cap sync && cap run android",
    "cap:add:android": "cap add android",
    "tauri": "tauri",
    "tauri:dev": "npm run build:server && tauri dev",
    "tauri:build": "npm run build:server && npm run build && tauri build"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@tauri-apps/api": "^2.11.1",
    "bonjour-service": "^1.4.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.511.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "tailwind-merge": "^3.0.2",
    "ws": "^8.18.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^9.25.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "concurrently": "^9.1.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
