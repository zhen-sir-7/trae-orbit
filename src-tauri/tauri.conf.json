{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "trae-orbit",
  "version": "0.1.0",
  "identifier": "com.trae.orbit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8787/desktop.html",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TRAE Orbit",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "http://localhost:8787/desktop.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../dist-server/server.mjs"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
